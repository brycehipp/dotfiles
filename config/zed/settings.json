// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
//
// Many of these settings came from joelazar's dotfiles
// https://github.com/joelazar/dotfiles/blob/main/dot_config/zed/
{
  // ══════════════════════════════════════════════════════════════════════════════
  // APPEARANCE
  // ══════════════════════════════════════════════════════════════════════════════
  "debugger": {
    "button": false,
  },
  "search": {
    "button": false,
  },
  "toolbar": {
    "code_actions": false,
    "agent_review": true,
    "selections_menu": true,
    // "quick_actions": false,
    "breadcrumbs": true,
  },
  "status_bar": {
    "show_active_file": false,
    "cursor_position_button": true,
    "active_language_button": true,
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Plastic - Deprioritised Punctuation",
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Latte",
  },
  "ui_font_size": 20.0,
  "agent_ui_font_size": 20.0,
  "agent_buffer_font_size": 16.0,
  "buffer_font_size": 16.0,
  "buffer_font_family": "Maple Mono NF",
  "buffer_font_features": {
    "calt": true, // standard ligatures (-> => != etc)
    "cv02": true, // alternative `a` with top arm
    "cv05": true, // alternative `g` in double story style
    "cv61": true, // alternative `,` and `;` with straight tail
    "cv63": true, // alternative `<=` in arrow style
  },
  "buffer_line_height": {
    "custom": 1.75,
  },
  "cursor_blink": true,
  "cursor_shape": "block",
  "colorize_brackets": true, // rainbow brackets
  "document_symbols": "on",
  "unnecessary_code_fade": 0.4,
  "wrap_guides": [120],

  // ══════════════════════════════════════════════════════════════════════════════
  // EDITOR BEHAVIOR
  // ══════════════════════════════════════════════════════════════════════════════
  // "base_keymap": "VSCode",
  "vim_mode": false,
  "tab_size": 2,
  "autosave": "on_focus_change",
  "preferred_line_length": 120,
  "double_click_in_multibuffer": "open", // double-click opens file instead of selecting
  "use_smartcase_search": true, // case-insensitive unless uppercase used
  "auto_indent": "preserve_indent",
  "show_whitespaces": "all",
  "ensure_final_newline_on_save": true,

  // ══════════════════════════════════════════════════════════════════════════════
  // WHICH-KEY (shows keybinding hints after delay)
  // ══════════════════════════════════════════════════════════════════════════════
  "which_key": {
    "enabled": true,
    "delay_ms": 400,
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // GIT INTEGRATION
  // ══════════════════════════════════════════════════════════════════════════════
  "git": {
    "inline_blame": {
      "delay_ms": 200,
      "show_commit_summary": true,
    },
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // INLAY HINTS & INDENT GUIDES
  // ══════════════════════════════════════════════════════════════════════════════
  "inlay_hints": {
    // "enabled": true,
  },
  "indent_guides": {
    "coloring": "indent_aware", // different colors per indent level
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // PREVIEW TABS
  // ══════════════════════════════════════════════════════════════════════════════
  "preview_tabs": {
    "enabled": true,
    "enable_keep_preview_on_code_navigation": true,
    "enable_preview_from_file_finder": true,
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // MULTIBUFFER / EXCERPTS (search results, references)
  // ══════════════════════════════════════════════════════════════════════════════
  "excerpt_context_lines": 3,
  "expand_excerpt_lines": 10,

  // ══════════════════════════════════════════════════════════════════════════════
  // SEARCH
  // ══════════════════════════════════════════════════════════════════════════════
  "seed_search_query_from_cursor": "selection", // only use selected text

  // ══════════════════════════════════════════════════════════════════════════════
  // SESSION
  // ══════════════════════════════════════════════════════════════════════════════
  "session": {
    "trust_all_worktrees": true,
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // WINDOW & LAYOUT
  // ══════════════════════════════════════════════════════════════════════════════
  "use_system_window_tabs": true,
  "restore_on_startup": "last_session",
  "bottom_dock_layout": "right_aligned",
  "centered_layout": {
    "left_padding": 0.15,
    "right_padding": 0.15,
  },
  "active_pane_modifiers": {
    "inactive_opacity": 0.75,
    "border_size": 0.5,
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // TITLE BAR
  // ══════════════════════════════════════════════════════════════════════════════
  "title_bar": {
    "show_user_picture": false,
    "show_onboarding_banner": true,
    "show_project_items": true,
    "show_branch_name": true,
    "show_user_menu": false,
    "show_menus": true,
    "show_sign_in": false,
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // TAB BAR & TABS
  // ══════════════════════════════════════════════════════════════════════════════
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false,
    "show": true,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "tabs": {
    "show_diagnostics": "errors",
    "git_status": true,
    "file_icons": true,
    "activate_on_close": "neighbour",
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // SCROLLBAR
  // ══════════════════════════════════════════════════════════════════════════════
  "scrollbar": {
    "show": "system",
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // PANELS
  // ══════════════════════════════════════════════════════════════════════════════
  "project_panel": {
    "dock": "right",
    "button": false,
    "default_width": 550,
    "auto_fold_dirs": false,
    "auto_reveal_entries": false,
    "entry_spacing": "standard",
    "diagnostic_badges": true,
    "git_status_indicator": true, // show git status colors on files in project panel
  },
  "outline_panel": {
    "button": false,
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
    "button": false,
    "default_width": 550,
  },
  "git_panel": {
    "dock": "right",
    "button": false,
    "tree_view": true,
    "sort_by_path": true,
    "default_width": 550,
    "show_count_badge": true,
    "file_icons": true,
    "status_style": "icon", // show git status as icons (alternative: "label_color")
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // FILE FINDER
  // ══════════════════════════════════════════════════════════════════════════════
  "file_finder": {
    "modal_max_width": "small",
    "include_ignored": "all",
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // DIAGNOSTICS
  // ══════════════════════════════════════════════════════════════════════════════
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // MESSAGES & CALLS
  // ══════════════════════════════════════════════════════════════════════════════
  "message_editor": {
    "auto_replace_emoji_shortcode": false,
  },
  "calls": {
    "mute_on_join": true,
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // AI / EDIT PREDICTIONS
  // ══════════════════════════════════════════════════════════════════════════════
  // ══════════════════════════════════════════════════════════════════════════════
  // AGENT (AI Assistant)
  // ══════════════════════════════════════════════════════════════════════════════
  "edit_predictions": {
    "disabled_globs": [],
    "provider": "zed",
  },
  "agent": {
    "dock": "left",
    "max_content_width": 1000.0,
    "button": false,
    "single_file_review": false,
    "tool_permissions": {
      "default": "allow",
    },
    // "inline_assistant_model": {
    //   "provider": "zed.dev",
    //   "model": "",
    // },
    "use_modifier_to_send": true,
    "play_sound_when_agent_done": "always",
    "show_turn_stats": true, // show timer + token count per turn
    // "commit_message_model": {
    //   "provider": "copilot_chat",
    //   "model": "gpt-5.4-mini",
    // },
    "enable_feedback": false,
    // "default_model": {
    //   "effort": "medium",
    //   "enable_thinking": true,
    //   "provider": "copilot_chat",
    //   "model": "claude-sonnet-4.6",
    // },
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // AGENT SERVERS (external AI agents)
  // ══════════════════════════════════════════════════════════════════════════════
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
      "default_mode": "full-access",
    },
    "cursor": {
      "type": "registry",
      "default_mode": "full-access",
    },
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // MCP / CONTEXT SERVERS
  // ══════════════════════════════════════════════════════════════════════════════
  "context_servers": {
    "postgres-context-server": {
      "enabled": true,
      "remote": false,
      "settings": {
        "database_url": "postgresql://postgres:p0stgres@localhost:5432/head",
      },
    },
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // TERMINAL
  // ══════════════════════════════════════════════════════════════════════════════
  "terminal": {
    "button": false,
    "scrollbar": {
      "show": "never",
    },
    "max_scroll_history_lines": 50000,
    "blinking": "on",
    "font_size": 18.0,
    "font_family": "Maple Mono NF",
    "font_features": {
      "calt": true,
      "cv02": true,
      "cv05": true,
      "cv61": true,
      "cv63": true,
    },
    "env": {
      "GIT_EDITOR": "zed --wait",
      "EDITOR": "zed",
    },
    "minimum_contrast": 0,
    "keep_selection_on_copy": false,
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // READ-ONLY FILES (prevent accidental edits)
  // ══════════════════════════════════════════════════════════════════════════════
  "read_only_files": ["**/*.lock", "**/vendor/**", "**/node_modules/**"],

  // ══════════════════════════════════════════════════════════════════════════════
  // FILE SCAN INCLUSIONS
  // ══════════════════════════════════════════════════════════════════════════════
  "file_scan_inclusions": [".env", ".env*"],

  // ══════════════════════════════════════════════════════════════════════════════
  // FILE SCAN EXCLUSIONS (performance)
  // ══════════════════════════════════════════════════════════════════════════════
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/.idea",
    "**/.serverless",
    "**/build",
    "**/dist",
    "**/coverage",
    "**/.venv",
    "**/__pycache__",
    "**/.ropeproject",
    "**/.pytest_cache",
    "**/.ruff_cache",
    "**/node_modules",
    "**/.pnpm-store",
  ],

  // ══════════════════════════════════════════════════════════════════════════════
  // FILE TYPE ASSOCIATIONS
  // ══════════════════════════════════════════════════════════════════════════════
  "file_types": {
    "Dockerfile": ["Dockerfile*"],
    "Shell Script": ["*.envrc*"],
    "Nginx": ["**/nginx/**/*.conf", "nginx.conf"],
    "json": [".cflintrc"],
    "rmacro": ["*.dnd"],
    "postcss": ["*.css"],
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // LANGUAGE-SPECIFIC SETTINGS
  // ══════════════════════════════════════════════════════════════════════════════
  "languages": {
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
      "inlay_hints": {
        "show_type_hints": true,
        "show_value_hints": true,
      },
    },
    "SQL": {
      "formatter": "prettier",
    },
    "JSON": {
      "prettier": {
        "allowed": true,
        "parser": "json",
      },
    },
    "Markdown": {
      "format_on_save": "on",
    },
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // LANGUAGE FORMATTER SETTINGS
  // ══════════════════════════════════════════════════════════════════════════════
  "prettier": {
    "parser": "JavaScript,TypeScript",
    "allowed": true,
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // AUTO-INSTALL EXTENSIONS
  // ══════════════════════════════════════════════════════════════════════════════
  "auto_install_extensions": {
    // languages / grammars
    "basher": true,
    "cfml": true,
    "csv": true,
    "docker-compose": true,
    "dockerfile": true,
    "env": true,
    "editorconfig": true,
    "git-firefly": true,
    "github-actions": true,
    "html": true,
    "log": true,
    "markdown-oxide": true,
    "nginx": true,
    "nix": true,
    "prisma": true,
    "rainbow-csv": true,
    "scss": true,
    "sql": true,
    "terraform": true,
    "tokyo-night": true,
    "toml": true,
    "xml": true,
    "vue": true,

    // themes
    "catppuccin-icons": true,
    "plastic-theme": true,

    // AI
    "postgres-context-server": true,
  },

  // ══════════════════════════════════════════════════════════════════════════════
  // THEME OVERRIDES
  // ══════════════════════════════════════════════════════════════════════════════
  "experimental.theme_overrides": {
    "syntax": {
      "comment": {
        "font_style": "italic",
      },
    },
    "players": [
      // matches the plastic theme
      {
        "cursor": "#A3B6D1ff",
        "background": "#A3B6D1ff",
        "selection": "#A3B6D133",
      },
    ],
  },
}
